# Bootstrap config only — never put secrets here (foundation iron rule 3)
OPENRAG_DATABASE_URL=postgresql+asyncpg://openrag:openrag@127.0.0.1:55432/openrag
OPENRAG_REDIS_URL=redis://127.0.0.1:56379/0
OPENRAG_ENVIRONMENT=dev
OPENRAG_QDRANT_URL=http://localhost:56333
OPENRAG_MINIO_ENDPOINT=http://localhost:59000
OPENRAG_MINIO_ACCESS_KEY=openrag
OPENRAG_MINIO_SECRET_KEY=openrag123
OPENRAG_MINIO_BUCKET=openrag-documents
OPENRAG_TEI_URL=http://localhost:58080
OPENRAG_EMBEDDING_BACKEND=tei
# KEK keyfile path — the only out-of-database application secret.
OPENRAG_KEK_FILE=./data/openrag_kek
# LiteLLM bootstrap credential. Provider keys belong in /admin/secrets.
LITELLM_MASTER_KEY=sk-openrag-dev-master
OPENRAG_LITELLM_URL=http://localhost:54000
OPENRAG_LITELLM_MASTER_KEY=sk-openrag-dev-master
