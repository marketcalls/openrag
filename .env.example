# Bootstrap config only — never put secrets here (foundation iron rule 3)
OPENRAG_DATABASE_URL=postgresql+asyncpg://openrag:openrag@127.0.0.1:55432/openrag
OPENRAG_REDIS_URL=redis://127.0.0.1:56379/0
OPENRAG_ENVIRONMENT=dev
OPENRAG_API_PORT=8000
OPENRAG_WEB_PORT=5173
OPENRAG_OLLAMA_PORT=11434
OPENRAG_QDRANT_URL=http://localhost:56333
OPENRAG_MINIO_ENDPOINT=http://localhost:59000
OPENRAG_MINIO_ACCESS_KEY=openrag
OPENRAG_MINIO_SECRET_KEY=openrag123
OPENRAG_MINIO_BUCKET=openrag-documents
OPENRAG_TEI_URL=http://localhost:58080
# `hash` needs no model download. Use `tei` with the Compose `ml` profile.
OPENRAG_EMBEDDING_BACKEND=hash
OPENRAG_EMBEDDING_DIM=1024
# Keep false while deploying the revision-fenced ingest protocol. See the
# rolling-upgrade runbook in README.md before enabling it.
OPENRAG_INGEST_REVISION_PROTOCOL_V2_ENABLED=false
OPENRAG_STALE_INGEST_RECOVERY_SECONDS=900
# KEK keyfile path — the only out-of-database application secret.
OPENRAG_KEK_FILE=./data/openrag_kek
# Development-only first-run account. Change both values outside local development.
OPENRAG_BOOTSTRAP_EMAIL=root@openrag.internal
OPENRAG_BOOTSTRAP_PASSWORD=changeme123
# LiteLLM bootstrap credential. Provider keys belong in /admin/secrets.
LITELLM_MASTER_KEY=sk-openrag-dev-master
OPENRAG_LITELLM_URL=http://localhost:54000
OPENRAG_LITELLM_MASTER_KEY=sk-openrag-dev-master

# Default stack:
# docker compose -f deploy/compose.yaml up -d --build
# Optional local ML services:
# OPENRAG_EMBEDDING_BACKEND=tei docker compose -f deploy/compose.yaml --profile ml up -d --build
